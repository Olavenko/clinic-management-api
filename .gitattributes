# Auto-detect text files and normalize line endings to LF in the repo
* text=auto

# C# source files
*.cs text diff=csharp
*.csx text diff=csharp
*.sln text eol=crlf
*.slnx text eol=crlf
*.csproj text eol=crlf

# Config & build files
*.props text eol=crlf
*.targets text eol=crlf
*.config text eol=crlf
*.json text
*.xml text
*.yml text
*.yaml text
*.md text

# Shell scripts (must stay LF even on Windows checkout)
*.sh text eol=lf

# Binary files (never diff or normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
*.pdb binary
