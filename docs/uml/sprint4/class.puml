@startuml
' -------------------------------------------------------
' File: class.puml
' -------------------------------------------------------
' Purpose   : Class Diagram — Doctor Domain & Service Architecture
' Layer     : Docs (UML)
' Author    : Mohamed Ali
' Created   : 2026-03-15
' Sprint    : 4 — Doctors CRUD + Role-based Authorization
' -------------------------------------------------------

!define USE_CUSTOM_THEME
!include ../config/style.puml

title Class Diagram — Doctor Domain Architecture (Sprint 4)

' === Header/Footer ===
header Clinic Management System - Domain Model
footer Doctor Module Structural Design

' === Layout Settings ===
skinparam groupInheritance 2
skinparam nodesep 60
skinparam ranksep 60

' === Packages ===

package "ClinicManagementAPI.Core.Interfaces" #161B22 {

    interface "<color:#A371F7><&shield></color> ISoftDeletable" << Interface >> {
        + IsDeleted : bool
        + DeletedAt : DateTime?
    }

    interface "IPatientService" << Interface >> {
        + GetAllAsync(pagination: PaginationRequest) : Task<Result<PagedResponse<PatientResponse>>>
        + GetByIdAsync(id: int) : Task<Result<PatientResponse>>
        + CreateAsync(request: CreatePatientRequest) : Task<Result<PatientResponse>>
        + UpdateAsync(id: int, request: UpdatePatientRequest) : Task<Result<PatientResponse>>
        + DeleteAsync(id: int) : Task<Result<bool>>
    }

    interface "IDoctorService" << Interface >> {
        + GetAllAsync(pagination: PaginationRequest) : Task<Result<PagedResponse<DoctorResponse>>>
        + GetAvailableAsync(pagination: PaginationRequest) : Task<Result<PagedResponse<DoctorResponse>>>
        + GetByIdAsync(id: int) : Task<Result<DoctorResponse>>
        + CreateAsync(request: CreateDoctorRequest) : Task<Result<DoctorResponse>>
        + UpdateAsync(id: int, request: UpdateDoctorRequest) : Task<Result<DoctorResponse>>
        + DeleteAsync(id: int) : Task<Result<bool>>
    }

    interface "IAuthService" << Interface >> {
        + RegisterAsync(req: RegisterRequest) : Task<Result<AuthResponse>>
        + LoginAsync(req: LoginRequest) : Task<Result<AuthResponse>>
        + RefreshTokenAsync(token: string) : Task<Result<AuthResponse>>
        + RevokeTokenAsync(token: string) : Task<Result<bool>>
        + AssignRoleAsync(userId: string, req: AssignRoleRequest) : Task<Result<bool>>
    }
}

package "ClinicManagementAPI.Core.Models" #0D1117 {

    class "<color:#3FB950><&box></color> Result<T>" << (S,#3FB950) Structure >> {
        + IsSuccess : bool
        + Value : T
        + Error : string
        + StatusCode : int
        {static} + Success(value: T) : Result<T>
        {static} + Failure(error: string, code: int) : Result<T>
    }

    class "<color:#E6EDF3><&person></color> ApplicationUser" << (E,#D29922) Entity >> {
        + FullName : string
        + CreatedAt : DateTime
        -- Identity Properties --
        + Email : string
        + UserName : string
    }

    class "<color:#58A6FF><&medical-cross></color> Patient" << (E,#D29922) Entity >> {
        + Id : int
        + FullName : string
        + Email : string
        + Phone : string
        + DateOfBirth : DateOnly
        + Gender : Gender
        + Address : string?
        + CreatedAt : DateTime
        + UpdatedAt : DateTime?
        -- Optional FK --
        + UserId : string?
        -- ISoftDeletable --
        + IsDeleted : bool
        + DeletedAt : DateTime?
    }

    class "<color:#3FB950><&stethoscope></color> Doctor" << (E,#D29922) Entity >> {
        + Id : int
        + FullName : string
        + Email : string
        + Phone : string
        + Specialization : string
        + YearsOfExperience : int
        + Bio : string?
        + IsAvailable : bool
        + CreatedAt : DateTime
        + UpdatedAt : DateTime?
        -- ISoftDeletable --
        + IsDeleted : bool
        + DeletedAt : DateTime?
    }
}

package "ClinicManagementAPI.Core.DTOs.Doctors" #161B22 {

    class "CreateDoctorRequest" << DTO >> {
        + FullName : string <<Required, MinLen(2), MaxLen(100)>>
        + Email : string <<Required, EmailAddress>>
        + Phone : string <<Required, Phone>>
        + Specialization : string <<Required, MaxLen(100)>>
        + YearsOfExperience : int <<Required, Range(0,60)>>
        + Bio : string? <<MaxLen(500)>>
    }

    class "UpdateDoctorRequest" << DTO >> {
        + FullName : string? <<MinLen(2), MaxLen(100)>>
        + Email : string? <<EmailAddress>>
        + Phone : string? <<Phone>>
        + Specialization : string? <<MaxLen(100)>>
        + YearsOfExperience : int? <<Range(0,60)>>
        + Bio : string? <<MaxLen(500)>>
        + IsAvailable : bool?
    }

    class "DoctorResponse" << DTO >> {
        + Id : int
        + FullName : string
        + Email : string
        + Phone : string
        + Specialization : string
        + YearsOfExperience : int
        + Bio : string?
        + IsAvailable : bool
        + CreatedAt : DateTime
        + UpdatedAt : DateTime?
    }
}

package "ClinicManagementAPI.Core.DTOs" #161B22 {

    class "PaginationRequest" << DTO >> {
        + Page : int <<default=1, Range(1,+inf)>>
        + PageSize : int <<default=10, Range(1,50)>>
        + SearchTerm : string?
    }

    class "PagedResponse<T>" << DTO >> {
        + Items : IEnumerable<T>
        + Page : int
        + PageSize : int
        + TotalCount : int
        + TotalPages : int <<computed>>
        + HasNext : bool <<computed>>
        + HasPrevious : bool <<computed>>
    }
}

' === Relationships ===

' (1) Patient implements ISoftDeletable
Patient .up.|> ISoftDeletable : " (1) Implements "

' (2) Doctor implements ISoftDeletable
Doctor .up.|> ISoftDeletable : " (2) Implements "

' (3) PatientService implements IPatientService
"ClinicManagementAPI.Core.Services.PatientService" .up.|> IPatientService : " (3) Realizes "

' (4) DoctorService implements IDoctorService
"ClinicManagementAPI.Core.Services.DoctorService" .up.|> IDoctorService : " (4) Realizes "

' (5) IDoctorService returns Result<T>
IDoctorService -[#3FB950]right-> "Result<T>" : " (5) Wraps "

' (6) Service consumes CreateDoctorRequest
CreateDoctorRequest -[#58A6FF]right-> IDoctorService : " (6) Input "

' (7) Service consumes UpdateDoctorRequest
UpdateDoctorRequest -[#58A6FF]right-> IDoctorService : " (7) Input "

' (8) Service returns DoctorResponse
IDoctorService -[#58A6FF]down-> DoctorResponse : " (8) Output "

' (9) Service consumes PaginationRequest
PaginationRequest -[#58A6FF]right-> IDoctorService : " (9) Input "

' (10) Service returns PagedResponse
IDoctorService -[#58A6FF]down-> "PagedResponse<T>" : " (10) Wraps Output "

' === Notes ===

note top of Doctor
    Email has **Filtered Unique Index**
    (IsDeleted = 0) at database level.
    Global Query Filter auto-excludes
    deleted doctors from queries.
    ----
    **IsAvailable** controls whether
    a doctor can accept appointments.
    GetAvailableAsync filters on this.
end note

note bottom of ISoftDeletable
    Reusable contract for soft delete.
    Used by Patient (Sprint 3) and
    Doctor (Sprint 4).
end note

note right of UpdateDoctorRequest
    All fields optional for
    **partial update**. Service
    rejects if all fields are null.
    Includes **IsAvailable** toggle.
end note

@enduml
