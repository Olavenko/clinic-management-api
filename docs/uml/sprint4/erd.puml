@startuml
' -------------------------------------------------------
' File: erd.puml
' -------------------------------------------------------
' Purpose   : ERD — Database Schema with Doctor Table added
' Layer     : Docs (UML)
' Author    : Mohamed Ali
' Created   : 2026-03-15
' Sprint    : 4 — Doctors CRUD + Role-based Authorization
' -------------------------------------------------------

!define USE_CUSTOM_THEME
!include ../config/style.puml

title ERD — Database Schema (Sprint 4)

' === Header/Footer ===
header Clinic Management System - Database Design
footer Sprint 4 — Patient, Doctor & Identity Tables

' === Layout Settings ===
skinparam nodesep 80
skinparam ranksep 60

' === Tables ===

package "Patient Management" #0D1117 {

    entity "<color:#58A6FF><&medical-cross></color> Patients" as PATIENTS << Table >> {
        * **Id** : int <<PK, Identity>>
        --
        * FullName : nvarchar(100)
        * Email : nvarchar(450) <<UK, Filtered: IsDeleted=0>>
        * Phone : nvarchar(max)
        * DateOfBirth : date
        * Gender : int <<enum>>
        Address : nvarchar(250) <<nullable>>
        * CreatedAt : datetime2
        UpdatedAt : datetime2 <<nullable>>
        --
        UserId : nvarchar(450) <<FK, nullable>>
        --
        * IsDeleted : bit <<default: 0>>
        DeletedAt : datetime2 <<nullable>>
    }
}

package "Doctor Management" #0D1117 {

    entity "<color:#3FB950><&stethoscope></color> Doctors" as DOCTORS << Table >> {
        * **Id** : int <<PK, Identity>>
        --
        * FullName : nvarchar(100)
        * Email : nvarchar(450) <<UK, Filtered: IsDeleted=0>>
        * Phone : nvarchar(max)
        * Specialization : nvarchar(100)
        * YearsOfExperience : int
        Bio : nvarchar(500) <<nullable>>
        * IsAvailable : bit <<default: 1>>
        * CreatedAt : datetime2
        UpdatedAt : datetime2 <<nullable>>
        --
        * IsDeleted : bit <<default: 0>>
        DeletedAt : datetime2 <<nullable>>
    }
}

package "ASP.NET Core Identity" #161B22 {

    entity "<color:#3FB950><&person></color> AspNetUsers" as USERS << Table >> {
        * **Id** : nvarchar(450) <<PK>>
        --
        * FullName : nvarchar(max)
        * Email : nvarchar(256) <<Unique>>
        * UserName : nvarchar(256) <<Unique>>
        * PasswordHash : nvarchar(max)
        * CreatedAt : datetime2
        SecurityStamp : nvarchar(max)
        ConcurrencyStamp : nvarchar(max)
        --
        ... other Identity columns ...
    }

    entity "<color:#A371F7><&shield></color> AspNetRoles" as ROLES << Table >> {
        * **Id** : nvarchar(450) <<PK>>
        --
        * Name : nvarchar(256) <<Unique>>
        NormalizedName : nvarchar(256)
        ConcurrencyStamp : nvarchar(max)
    }

    entity "<color:#D29922><&link-intact></color> AspNetUserRoles" as USER_ROLES << Junction >> {
        * **UserId** : nvarchar(450) <<PK, FK>>
        * **RoleId** : nvarchar(450) <<PK, FK>>
    }

    entity "<color:#D29922><&key></color> RefreshTokens" as TOKENS << Table >> {
        * **Id** : int <<PK, Identity>>
        --
        * Token : nvarchar(max)
        * ExpiresAt : datetime2
        * CreatedAt : datetime2
        * IsRevoked : bit
        --
        * UserId : nvarchar(450) <<FK>>
    }
}

' === Relationships ===

' (1) Patient optionally links to a User
PATIENTS }o..|| USERS : " (1) Optional FK\n(UserId -> Id) "

' (2) User has many Refresh Tokens
USERS ||--o{ TOKENS : " (2) Owns\n(UserId -> Id) "

' (3) User-Role junction: Assigned
USERS ||--o{ USER_ROLES : " (3) Assigned "

' (4) User-Role junction: Contains
ROLES ||--o{ USER_ROLES : " (4) Contains "

' === Notes ===

note right of PATIENTS
    **Filtered Unique Index** on Email:
    ""HasFilter("IsDeleted = 0")""
    ----
    Active emails must be unique.
    Service checks ALL patients via
    ""IgnoreQueryFilters()"".
    ----
    **Global Query Filter**:
    ""HasQueryFilter(p => !p.IsDeleted)""
end note

note right of DOCTORS
    **Same soft delete pattern as Patients.**
    ----
    **Filtered Unique Index** on Email:
    ""HasFilter("IsDeleted = 0")""
    ----
    **IsAvailable** (default: true)
    controls appointment booking
    eligibility (Sprint 5).
    ----
    **Global Query Filter**:
    ""HasQueryFilter(d => !d.IsDeleted)""
    ----
    No FK to AspNetUsers — doctors
    are managed by Admin, not
    linked to login accounts.
end note

note bottom of ROLES
    Seeded Roles:
    * **Admin** — Full access
    * **Doctor** — (Sprint 5)
    * **Receptionist** — Patient CRUD
    * **Patient** — Default role
    ----
    Each user has exactly
    **one role** at a time.
end note

@enduml
